
# DATABASE (NEON POSTGRES)
POSTGRES_URL="postgresql://user:pass@ep-xyz.aws.neon.tech/neondb?sslmode=require"

# APP DOMAIN (REQUIRED FOR PRODUCTION)
PUBLIC_BASE_URL="https://your-app-domain.com"

# AI INTELLIGENCE
GEMINI_API_KEY="AIza..."

# WHATSAPP API (META)
META_API_TOKEN="EAAG..."
PHONE_NUMBER_ID="123456789"
VERIFY_TOKEN="uber_fleet_verify_token"

# AWS S3 (MEDIA STORAGE)
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="secret..."
AWS_BUCKET_NAME="uber-fleet-assets"
AWS_REGION="us-east-1"

# GOOGLE AUTH
VITE_GOOGLE_CLIENT_ID="client-id"

# PERFORMANCE (UPSTASH)
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"
QSTASH_TOKEN="your-qstash-token"

# QSTASH SECURITY (CRITICAL: Get from Upstash Console > QStash > Signing Keys)
QSTASH_CURRENT_SIGNING_KEY="sig_..."
QSTASH_NEXT_SIGNING_KEY="sig_..."

# GOOGLE SHEETS DRIVER EXCEL SYNC (OPTIONAL)
GOOGLE_SHEETS_SPREADSHEET_ID="1abc..."
# Tab (worksheet) names INSIDE the same spreadsheet (not separate files)
# Example: Spreadsheet file id=XYZ can contain tabs named "Customers" and "Messages"
GOOGLE_SHEETS_CUSTOMERS_TAB_NAME="Customers"
GOOGLE_SHEETS_MESSAGES_TAB_NAME="Messages"
GOOGLE_SERVICE_ACCOUNT_EMAIL="driver-sync@your-project.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# DRIVER EXCEL SYNC TUNING (OPTIONAL)
# Wait for this quiet window before running heavy S3 + Google Sheets sync
DRIVER_EXCEL_SYNC_IDLE_MS="20000"
# Hard deadline to force sync even during continuous traffic
DRIVER_EXCEL_SYNC_MAX_WAIT_MS="180000"

# GOOGLE SHEETS INCREMENTAL SYNC TUNING (OPTIONAL)
# Small buffer to batch frequent row edits/new leads before pushing to Sheets
DRIVER_EXCEL_INCREMENTAL_SYNC_IDLE_MS="2500"
# Hard deadline for incremental queue flush under constant load
DRIVER_EXCEL_INCREMENTAL_SYNC_MAX_WAIT_MS="15000"

# WHATSAPP BOT LATENCY TUNING (OPTIONAL)
# Delay between auto-advanced bot nodes (lower = faster conversational response)
BOT_ENGINE_AUTO_ADVANCE_DELAY_MS="15"
# Max delay-node wait cap inside bot graph to prevent long slowdowns in live chat
BOT_ENGINE_DELAY_NODE_CAP_MS="800"
# Drop stale deferred bot jobs that exceeded queue wait budget
WEBHOOK_DEFER_MAX_QUEUE_WAIT_MS="15000"
# Coalesce deferred jobs per lead so latest customer intent is processed first
FF_WEBHOOK_DEFER_COALESCE="true"

# Prioritize instant reply for inbound-triggered flows by compressing delay nodes
FF_BOT_PRIORITIZE_INBOUND_REPLY="true"
# Max delay node wait during inbound-triggered runs
BOT_ENGINE_INBOUND_DELAY_CAP_MS="120"
