{
  "name": "uber-fleet-recruiter",
  "version": "1.0.0",
  "description": "WhatsApp Recruitment Automation for Uber Fleet",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:critical": "node --test tests/critical-flows.test.js",
    "test:smoke": "node scripts/run-smoke-checks.js",
    "test:rollback": "node scripts/run-rollback-validation.js",
    "release:gate": "node scripts/release-gate.js",
    "test:governance": "node --test tests/migration-governance.test.js",
    "check:boundaries": "node scripts/check-import-boundaries.js",
    "check:contracts": "node scripts/check-contract-versioning.js",
    "check:migration-evidence": "node scripts/check-migration-evidence.js",
    "contracts:catalog": "node scripts/generate-contract-catalog.js",
    "check:canary-perf": "node scripts/check-performance-canary.js",
    "check:sections-4-7": "node scripts/check-sections-4-7-readiness.js",
    "check:section1-hardening": "node scripts/check-section1-hardening.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "@google/genai": "latest",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "lucide-react": "^0.468.0",
    "pg": "^8.11.3",
    "@xyflow/react": "^12.0.0",
    "zustand": "^4.5.0",
    "@aws-sdk/client-s3": "^3.400.0",
    "@aws-sdk/s3-request-presigner": "^3.400.0",
    "multer": "^1.4.5-lts.1",
    "@react-oauth/google": "^0.12.1",
    "jwt-decode": "^4.0.0",
    "google-auth-library": "^9.4.1",
    "@upstash/redis": "^1.28.0",
    "@upstash/qstash": "^2.0.0"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
