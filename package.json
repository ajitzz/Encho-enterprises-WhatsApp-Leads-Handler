{
  "name": "uber-fleet-recruiter",
  "version": "1.0.0",
  "type": "module",
  "description": "WhatsApp Recruitment Automation for Uber Fleet",
  "main": "server.ts",
  "scripts": {
    "start": "tsx server.ts",
    "dev": "tsx server.ts",
    "lint": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "test:critical": "node --test tests/critical-flows.test.js",
    "test:smoke": "node scripts/run-smoke-checks.js",
    "test:rollback": "node scripts/run-rollback-validation.js",
    "release:gate": "node scripts/release-gate.js",
    "test:governance": "node --test tests/migration-governance.test.js",
    "check:boundaries": "node scripts/check-import-boundaries.js",
    "check:contracts": "node scripts/check-contract-versioning.js",
    "check:migration-evidence": "node scripts/check-migration-evidence.js",
    "contracts:catalog": "node scripts/generate-contract-catalog.js",
    "check:canary-perf": "node scripts/check-performance-canary.js",
    "check:sections-4-7": "node scripts/check-sections-4-7-readiness.js",
    "check:section1-hardening": "node scripts/check-section1-hardening.js",
    "check:sections-1-3": "node scripts/check-sections-1-3-readiness.js",
    "start:modular": "node backend/app/server.js",
    "check:rollout-modes": "node scripts/check-rollout-modes.js",
    "check:industrial-readiness": "node scripts/check-industrial-readiness.js",
    "estimate:transfer": "node scripts/estimate-network-transfer.js",
    "check:transfer-guardrails": "node scripts/check-transfer-guardrails.js",
    "estimate:transfer:edge": "node scripts/estimate-transfer-from-edge-metrics.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.400.0",
    "@aws-sdk/s3-request-presigner": "^3.400.0",
    "@google/genai": "latest",
    "@react-oauth/google": "^0.12.1",
    "@upstash/qstash": "^2.0.0",
    "@upstash/redis": "^1.28.0",
    "@xyflow/react": "^12.0.0",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^9.4.1",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.468.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.8.0",
    "zustand": "^4.5.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^5.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
